# CareerVine environment variables.
#
# Copy to .env.local and fill in. This file documents every var the app and its
# scripts read (via process.env or requireEnv), grouped by feature, each with
# the failure mode when it's unset. Real secret VALUES never live here.
#
# Coverage is enforced by src/__tests__/env-example-coverage.test.ts: any
# process.env / requireEnv var read under src or scripts must appear here (or on
# that test's platform skip-list), so this file can't silently drift stale.
#
# Convention: uncommented KEY= = required for the app to run in production;
# commented # KEY= = optional / dev-only / has a safe default.

# ── Supabase (database + auth) ────────────────────────────────────────────
# Unset → the app can't reach the database: every data load, sign-in, and
# service-role route fails.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (bypasses RLS). Server-only. Unset → all privileged paths
# (admin dashboard, crons, machine-token routes, scrape ingest, R2 sweeps) fail.
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Management API PAT — used only by scripts/configure-auth-emails.mjs
# to push auth email templates. Unset → that script can't authenticate.
# SUPABASE_ACCESS_TOKEN=

# ── Local Supabase overrides (dev only) ───────────────────────────────────
# Only consulted when NEXT_PUBLIC_SUPABASE_USE_PROD=false (lib/supabase/config.ts).
# Unset while USE_PROD=false → local dev falls back to prod credentials.
# NEXT_PUBLIC_SUPABASE_USE_PROD=false
# NEXT_PUBLIC_SUPABASE_URL_LOCAL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY_LOCAL=
# SUPABASE_SERVICE_ROLE_KEY_LOCAL=

# ── Encryption at rest ────────────────────────────────────────────────────
# AES-256-GCM key (lib/crypto.ts). Encrypts BYO OpenAI/Deepgram API keys AND
# Gmail OAuth access/refresh tokens at rest (CAR-27). Unset → BYO-key and Gmail
# token encrypt/decrypt throw; connecting Gmail and using stored keys break.
# Rotating it strands all previously encrypted values.
BYOK_ENCRYPTION_KEY=

# ── Google OAuth (Gmail + Calendar) ───────────────────────────────────────
# lib/oauth-helpers.ts + /api/gmail/callback. Unset → the Gmail/Calendar OAuth
# handshake fails, so no account can connect and token refresh dies.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Absolute OAuth redirect URI; must exactly match the Google console entry.
GOOGLE_REDIRECT_URI=

# ── Email (Resend = primary; SendGrid = dead) ─────────────────────────────
# Resend key (lib/notify/email.ts, follow-up-nudges cron). Unset → outbound
# notification/nudge emails silently don't send.
RESEND_API_KEY=
# SendGrid is dead (account expired, 2026-07-10) but lib/admin-notify.ts still
# reads this. Unset → admin infra alerts no-op. Do not rely on it.
# SENDGRID_API_KEY=

# ── OpenAI (AI drafts, suggestions, profile parsing) ──────────────────────
# lib/openai.ts. Unset → the shared-key AI features return "not configured"
# (BYO user keys still work). OPENAI_MODEL overrides the default model.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini
# Monthly per-user ceiling (USD) on estimated shared-key spend (CAR-143).
# Unset → $1. lib/ai/spend.ts.
# SHARED_AI_SPEND_LIMIT_USD=1

# ── Deepgram (meeting transcription) ──────────────────────────────────────
# lib/deepgram.ts. Unset → shared-key transcription is unavailable (BYO
# Deepgram keys still work).
DEEPGRAM_API_KEY=

# ── Serper (company / people web search) ──────────────────────────────────
# lib/serper.ts. Unset → company-page discovery and search enrichment degrade.
SERPER_API_KEY=

# ── Apify (LinkedIn scraping) ─────────────────────────────────────────────
# When any of the first three is unset the scrape features degrade to
# "disabled" (no 500s) — Refresh / Find-email / discovery report "not configured".
APIFY_API_TOKEN=
# Shared secret the Apify completion webhook presents back in the
# X-Careervine-Webhook-Secret header (lib/apify/client.ts, run-callback route).
# Mismatch → every completion callback 401s and paid runs orphan.
APIFY_WEBHOOK_SECRET=
# PUBLIC origin Apify's webhook POSTs to. MUST be the canonical, redirect-free
# host — a 307 (apex → www) drops the POST and orphans a paid run. Falls back to
# https://$VERCEL_URL when unset.
APP_BASE_URL=https://www.careervine.app
# Kill switch: "true" disables all scraping (triggers return disabled).
# APIFY_SCRAPE_DISABLED=false

# ── QStash (cron scheduling + signing) ────────────────────────────────────
# Cron schedules are declared in scripts/qstash-schedules.mjs (source of truth;
# run `node scripts/qstash-schedules.mjs list` to diff against live).
# Signing keys verify the upstash-signature on every /api/cron/* + queue route.
# Unset/wrong → all cron and queue-worker POSTs 401 ("Invalid signature").
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# QStash REST token — enqueues bundle-sync jobs (lib/bundle-queue.ts) and drives
# the schedule reconcile script. Unset → subscriber fan-out can't enqueue.
QSTASH_TOKEN=

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────
# lib/rate-limit.ts. Unset → rate limiting degrades to allow-all (logged once);
# the app still runs but per-user + machine-token limits stop being enforced.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cloudflare R2 (profile photo storage) ─────────────────────────────────
# lib/r2.ts + scripts/lib/r2-photos.mjs (via requireEnv). Unset → photo mirror,
# upload, and cleanup fail; bundle publish can't durably host LinkedIn photos.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for served R2 objects (lib/photo-urls.ts). Unset → stored
# photo keys can't be turned into displayable URLs.
R2_PUBLIC_BASE_URL=

# ── PostHog (product analytics) ───────────────────────────────────────────
# Public ingest key + host (lib/analytics/client.tsx, server.ts). Unset →
# analytics no-op (app unaffected).
NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side annotation/backfill scripts only (scripts/posthog-*.mjs).
# POSTHOG_PROJECT_ID=
# POSTHOG_PERSONAL_API_KEY=

# ── Admin / machine tokens ────────────────────────────────────────────────
# Bearer secret for the BUNDLE_ADMIN_TOKEN machine routes (bundles/publish,
# ai-access) and scripts/publish-bundle.mjs. Unset → those routes reject every
# request (401) and bundle publishing / AI-access grants are impossible.
BUNDLE_ADMIN_TOKEN=

# ── Notifications ─────────────────────────────────────────────────────────
# HMAC secret signing one-click unsubscribe tokens (lib/notify/tokens.ts,
# follow-up-nudges cron, notifications/unsubscribe route). Unset → unsubscribe
# links can't be signed or verified.
NUDGE_UNSUBSCRIBE_SECRET=

# ── App URLs / extension ──────────────────────────────────────────────────
# Canonical app origin used by the MCP auth config + nudge emails
# (mcp/auth-config.ts, follow-up-nudges cron). Unset → MCP OAuth metadata and
# email links fall back / break.
NEXT_PUBLIC_APP_URL=https://www.careervine.app
# Chrome Web Store listing URL surfaced in the UI (lib/extension-store.ts).
# NEXT_PUBLIC_EXTENSION_STORE_URL=

# ── Platform-injected (DO NOT set — documented for the coverage test) ─────
# These are provided automatically by the runtime and must not be set by hand:
#   NODE_ENV                   — Next.js/Node build mode
#   HOME                       — OS home dir (a test fixture reads it)
#   VERCEL_ENV                 — Vercel deployment environment
#   VERCEL_URL                 — Vercel-assigned deployment host (APP_BASE_URL fallback)
#   VERCEL_GIT_COMMIT_SHA      — Vercel build metadata
#   VERCEL_GIT_COMMIT_MESSAGE  — Vercel build metadata
