# CareerVine environment variables.
# Copy to .env.local and fill in. This file documents the vars the app reads;
# secrets never live here.

# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Local dev (optional): point at a local Supabase instead of prod
# NEXT_PUBLIC_SUPABASE_URL_LOCAL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY_LOCAL=
# SUPABASE_SERVICE_ROLE_KEY_LOCAL=
# NEXT_PUBLIC_SUPABASE_USE_PROD=false

# ── OpenAI (AI suggestions, profile parsing) ──────────────────────────
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini

# ── QStash (crons) ────────────────────────────────────────────────────
# Schedules live in the Upstash console:
#   /api/cron/send-follow-ups  — every 15 min
#   /api/cron/scrape-refresh   — daily (cadence re-scrape drip, plan 29)
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Apify LinkedIn scraping (plan 29 / CAR-15) ────────────────────────
# When any of these is unset the scrape features degrade to "disabled"
# (no 500s) — the Refresh / Find-email actions report "not configured".
APIFY_API_TOKEN=
# Shared secret the Apify completion webhook must present back to us.
APIFY_WEBHOOK_SECRET=
# The PUBLIC origin Apify's webhook posts to. MUST be the canonical,
# redirect-free host — if this 307-redirects (e.g. apex → www) the webhook
# POST is lost and a paid scrape run is orphaned. Use the host that serves 200.
APP_BASE_URL=https://www.careervine.app
# Kill switch: set to "true" to disable all scraping (triggers return disabled).
# APIFY_SCRAPE_DISABLED=false
